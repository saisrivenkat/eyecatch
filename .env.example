# Admin password — used to log into /admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session signing secret — MUST be at least 16 characters, random
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-16-chars

# Vercel Blob token — auto-added when you enable Vercel Blob in your project
# Dashboard: Vercel project → Storage → Create Database → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# Cloudflare R2 — used for video uploads (free egress, 10 GB free storage)
# Dashboard: Cloudflare → R2 → bucket Settings + Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
