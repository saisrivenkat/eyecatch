{
  "name": "ai-website-clone-template",
  "version": "0.3.1",
  "private": true,
  "description": "Clone any website into a clean, modern Next.js codebase using AI coding agents",
  "author": "JCodesMore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCodesMore/ai-website-cloner-template.git"
  },
  "homepage": "https://github.com/JCodesMore/ai-website-cloner-template",
  "bugs": {
    "url": "https://github.com/JCodesMore/ai-website-cloner-template/issues"
  },
  "keywords": [
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && next dev --no-server-fast-refresh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "generate:types": "payload generate:types",
    "payload": "payload",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "@vercel/blob": "^2.4.0",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "gsap": "^3.14.2",
    "jose": "^6.2.3",
    "lenis": "^1.3.21",
    "lucide-react": "^1.6.0",
    "next": "^16.2.4",
    "payload": "^3.84.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.12.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
